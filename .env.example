# Stripe Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create these in your Stripe Dashboard)
# Products > Create Product > Add Price > Copy the price ID
STRIPE_PRICE_SINGLE_REPORT=price_placeholder_single_report
STRIPE_PRICE_SINGLE_DATASET=price_placeholder_single_dataset
STRIPE_PRICE_SINGLE_CERT=price_placeholder_single_certification
STRIPE_PRICE_PRO_MONTHLY=price_placeholder_pro_monthly

# Your domain (for Stripe success/cancel redirects)
SITE_DOMAIN=https://trust-forged.com
